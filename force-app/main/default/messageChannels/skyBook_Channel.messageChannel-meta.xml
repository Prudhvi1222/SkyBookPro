<?xml version="1.0" encoding="UTF-8"?>
<LightningMessageChannel xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Message channel for SkyBook Pro booking and cancellation events.</description>
    <isExposed>true</isExposed>
    <lightningMessageFields>
        <description>Booking Id related to the event.</description>
        <fieldName>bookingId</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>Type of event such as BOOKING_CANCELLED.</description>
        <fieldName>eventType</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>Display message for subscribers.</description>
        <fieldName>message</fieldName>
    </lightningMessageFields>
    <masterLabel>SkyBook Channel</masterLabel>
</LightningMessageChannel>
